  "keyFeatures": [
    "High-performance NAT traversal with significantly higher throughput than frp",
    "Low resource consumption — binary as small as ~500KiB for embedded devices",
    "Multiple transport security options: Noise Protocol, TLS (native-tls and rustls), and WebSocket",
    "Per-service token authentication for secure, isolated service exposure",
    "Hot reload support — add or remove services without restarting",
    "TCP and UDP protocol forwarding",
    "Proxy support (SOCKS5 and HTTP) for connecting through firewalls",
    "Single binary that can run as both server and client"
  ],
  "publicApiSurface": [
    "rathole <config.toml>",
    "rathole --server <config.toml>",
    "rathole --client <config.toml>",
    "rathole --genkey [x25519|x448]",
    "[client] TOML config block",
    "[server] TOML config block",
    "[client.services.<name>] TOML config block",
    "[server.services.<name>] TOML config block",
    "[client.transport] / [server.transport] TOML config block",
    "transport.type: tcp | tls | noise | websocket",
    "RUST_LOG environment variable for log level control"
  ]
